{
  "name": "claude-auto-resume",
  "version": "2.0.9",
  "description": "Automatically resumes Claude CLI tasks when usage limits are lifted. Supports both npm install and npx usage. TypeScript-based with comprehensive tooling.",
  "main": "dist/index.js",
  "bin": {
    "claude-auto-resume": "dist/cli.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --watch",
    "build:prod": "tsup --minify",
    "dev": "ts-node src/index.ts",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:prod && npm run test",
    "version": "npm run build:prod && node scripts/update-changelog.js",
    "postversion": "git push && git push --tags",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "start": "node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terryso/claude-auto-resume.git"
  },
  "keywords": [
    "claude",
    "ai",
    "cli",
    "automation",
    "resume",
    "typescript"
  ],
  "author": "Nick <oxtiger@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/terryso/claude-auto-resume/issues"
  },
  "homepage": "https://github.com/terryso/claude-auto-resume#readme",
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.13",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "commander": "^14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/dist",
    "README.md",
    "LICENSE",
    "CLAUDE.md"
  ]
}
